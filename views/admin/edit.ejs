<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — 博客后台</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">

  <!-- 后台顶部导航 -->
  <header class="admin-header">
    <div class="admin-header-inner">
      <span class="admin-header-logo">博客后台</span>
      <nav class="admin-header-nav">
        <a href="/admin/articles" class="admin-nav-link">文章管理</a>
        <a href="/" class="admin-nav-link" target="_blank" rel="noopener">查看前台</a>
        <a href="/admin/logout" class="admin-nav-link admin-nav-logout">退出 (<%= username %>)</a>
      </nav>
    </div>
  </header>

  <main class="admin-main">
    <div class="admin-container">

      <!-- 面包屑 + 标题 -->
      <div class="admin-page-header">
        <div>
          <a href="/admin/articles" class="admin-breadcrumb">← 文章列表</a>
          <h2 class="admin-page-title"><%= isNew ? '新建文章' : '编辑文章' %></h2>
        </div>
        <% if (!isNew && article.status === 'published') { %>
          <a href="/article/<%= article.id %>" class="btn btn-ghost" target="_blank" rel="noopener">查看前台 →</a>
        <% } %>
      </div>

      <!-- 成功提示 -->
      <% if (typeof saved !== 'undefined' && saved) { %>
        <div class="alert alert-success" role="alert">保存成功！</div>
      <% } %>
      <% if (typeof created !== 'undefined' && created) { %>
        <div class="alert alert-success" role="alert">文章已创建！</div>
      <% } %>

      <!-- 错误提示 -->
      <% if (error) { %>
        <div class="alert alert-error" role="alert"><%= error %></div>
      <% } %>

      <!-- 编辑表单 -->
      <div class="edit-form">
        <form
          method="POST"
          action="<%= isNew ? '/admin/articles' : '/admin/articles/' + article.id %>"
          novalidate
          id="edit-article-form"
        >

          <!-- 标题 -->
          <div class="form-group">
            <label class="form-label" for="title">文章标题 <span style="color:var(--color-feedback-error)">*</span></label>
            <input
              class="form-control"
              style="font-size:18px; padding:12px 16px;"
              type="text"
              id="title"
              name="title"
              value="<%= article.title %>"
              placeholder="请输入文章标题"
              required
              autofocus
            >
          </div>

          <!-- 正文（纯文本 / Markdown） -->
          <div class="form-group">
            <label class="form-label" for="content">
              文章正文 <span style="color:var(--color-feedback-error)">*</span>
              <span class="form-hint" style="display:inline;margin-left:8px">支持 Markdown 语法</span>
            </label>
            <textarea
              class="form-control"
              id="content"
              name="content"
              rows="24"
              placeholder="在此输入文章内容（支持 Markdown）"
              required
            ><%= article.content %></textarea>
          </div>

          <!-- 标签 -->
          <div class="form-group">
            <label class="form-label" for="tags">
              标签
              <span class="form-hint" style="display:inline;margin-left:8px">多个标签用英文逗号分隔，如：技术, 生活</span>
            </label>
            <input
              class="form-control"
              type="text"
              id="tags"
              name="tags"
              value="<%= article.tags || '' %>"
              placeholder="技术, 生活, 随笔"
            >
          </div>

          <!-- 发布状态 -->
          <div class="form-group">
            <label class="form-label">发布状态</label>
            <div style="display:flex; gap:20px; margin-top:4px;">
              <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                <input
                  type="radio"
                  name="status"
                  value="draft"
                  id="status-draft"
                  <%= (!article.status || article.status === 'draft') ? 'checked' : '' %>
                >
                <span style="font-size:14px; color:var(--color-text-secondary)">草稿（仅后台可见）</span>
              </label>
              <label style="display:flex; align-items:center; gap:6px; cursor:pointer;">
                <input
                  type="radio"
                  name="status"
                  value="published"
                  id="status-published"
                  <%= article.status === 'published' ? 'checked' : '' %>
                >
                <span style="font-size:14px; color:var(--color-text-secondary)">已发布（前台可见）</span>
              </label>
            </div>
          </div>

          <!-- 操作按钮 -->
          <div style="display:flex; gap:12px; margin-top:32px; flex-wrap:wrap; align-items:center;">
            <button class="btn btn-primary" type="submit" id="btn-publish">发布文章</button>
            <button class="btn btn-ghost" type="submit" id="btn-draft">保存草稿</button>
            <a href="/admin/articles" class="btn btn-ghost" style="color:var(--color-text-secondary); border-color:var(--color-border);">取消</a>
          </div>

        </form>
      </div>

    </div>
  </main>

  <script>
    /* 点击「发布文章」→ 选中 published；点击「保存草稿」→ 选中 draft */
    (function() {
      var btnPublish = document.getElementById('btn-publish');
      var btnDraft   = document.getElementById('btn-draft');
      if (btnPublish) {
        btnPublish.addEventListener('click', function() {
          document.getElementById('status-published').checked = true;
        });
      }
      if (btnDraft) {
        btnDraft.addEventListener('click', function() {
          document.getElementById('status-draft').checked = true;
        });
      }
    })();
  </script>

</body>
</html>
