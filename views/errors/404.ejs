<%
  // 404 错误页不需要 profile 时提供默认值
  var _profile = typeof profile !== 'undefined' && profile ? profile : {
    name: '我的博客',
    tagline: '记录思考，分享所得',
    socialLinks: [],
    get copyrightYear() { return new Date().getFullYear(); }
  };
%>
<%- include('../layouts/_header', { profile: _profile, title: '页面不存在' }) %>

    <div class="error-page container">
      <div class="error-content">
        <p class="error-code">404</p>
        <h1 class="error-title">页面不见了</h1>
        <p class="error-desc">您访问的页面可能已被删除、移动或从未存在。</p>
        <a href="/" class="btn btn-primary">返回首页</a>
      </div>
    </div>

<%- include('../layouts/_footer', { profile: _profile }) %>
